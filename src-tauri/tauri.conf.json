{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "md-reader-app",
  "version": "0.1.0",
  "identifier": "com.theolempereur.mdreader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marque-page",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 420,
        "maximized": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
